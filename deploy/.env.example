# Claide Environment Configuration
# Copy this file to .env and fill in your values.
#
# Required: At least one LLM provider and one channel.

# ═══════════════════════════════════════════════
# LLM Provider (pick one)
# ═══════════════════════════════════════════════

# Anthropic Claude (recommended)
CLAIDE_PROVIDERS_ANTHROPIC_API_KEY=

# OpenAI
# CLAIDE_PROVIDERS_OPENAI_API_KEY=

# OpenRouter (access multiple models)
# CLAIDE_PROVIDERS_OPENROUTER_API_KEY=

# ═══════════════════════════════════════════════
# Channels (pick one or more)
# ═══════════════════════════════════════════════

# Telegram Bot
CLAIDE_CHANNELS_TELEGRAM_BOT_TOKEN=

# Discord Bot
# CLAIDE_CHANNELS_DISCORD_TOKEN=

# Slack Bot
# CLAIDE_CHANNELS_SLACK_BOT_TOKEN=
# CLAIDE_CHANNELS_SLACK_APP_TOKEN=

# ═══════════════════════════════════════════════
# Optional: Tools
# ═══════════════════════════════════════════════

# Web Search (Brave Search API)
# BRAVE_API_KEY=

# WhatsApp Business
# CLAIDE_TOOLS_WHATSAPP_PHONE_NUMBER_ID=
# CLAIDE_TOOLS_WHATSAPP_ACCESS_TOKEN=

# Google Sheets
# CLAIDE_TOOLS_GOOGLE_SHEETS_ACCESS_TOKEN=

# ═══════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════
RUST_LOG=claide=info
RUST_LOG_FORMAT=json
